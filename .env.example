# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys

# VITE_ prefix → exposed to browser (public key only — safe)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx

# Server-side only (Vercel serverless functions) — NEVER use VITE_ prefix
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here