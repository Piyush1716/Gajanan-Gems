# GajananGems Backend — Environment Variables

# Supabase (server-side — use service role key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Storage bucket names (used when building image URLs)
PRODUCT_BUCKET=
CATEGORY_BUCKET=

# Server
PORT=3001

# CORS — set to your frontend URL in production (e.g. https://gajanangems.com)
# Leave as * for local development
# ALLOWED_ORIGIN=http://localhost:5173
